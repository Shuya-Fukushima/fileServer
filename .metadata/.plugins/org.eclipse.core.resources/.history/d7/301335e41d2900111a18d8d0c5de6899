package com.shiku.file.transfer.domain;

import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import org.springframework.util.StringUtils;
import org.springframework.web.multipart.MultipartFile;

import com.shiku.file.util.db.repository.FileRepository;

@Service
public class FileTransferService {
	@Autowired
	private FileRepository fileRepo;
	
	@Value("${file.upload-dir:C:/uploads}")
	private Path rootDir;
	
	public String storeFile(MultipartFile file, String subDir) {
        // ファイル名のクリーンアップ（例: test.jpg）
        String fileName = StringUtils.cleanPath(file.getOriginalFilename());

        try {
            // IDごとのサブディレクトリを作成（例: ./uploads/123/）
            Path targetLocation = this.fileStorageLocation.resolve(subDir).resolve(fileName);
            Files.createDirectories(targetLocation.getParent());

            // ファイルを保存（既存ファイルがある場合は置換）
            file.transferTo(targetLocation);

            return fileName;
        } catch (IOException ex) {
            throw new RuntimeException("ファイルの保存に失敗しました: " + fileName, ex);
        }
    }
}
