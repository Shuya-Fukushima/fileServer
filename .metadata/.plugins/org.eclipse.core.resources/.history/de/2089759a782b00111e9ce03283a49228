package com.shiku.file.util.domain.service;

import java.nio.file.NoSuchFileException;
import java.nio.file.Path;
import java.sql.SQLException;
import java.util.List;
import java.util.UUID;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.dao.IncorrectResultSizeDataAccessException;
import org.springframework.data.util.Pair;
import org.springframework.stereotype.Service;

import com.shiku.file.util.inflastructure.repository.FileRepository;
import com.shiku.file.util.inflastructure.resource.File;
import com.shiku.file.util.inflastructure.resource.FilePathProjection;

@Service
public class FolderUtilService {

	@Autowired
	private FileRepository repo;

	@Value("${file.upload-dir:C:/uploads}")
	private Path rootDir;

	/** ユニーク保証件数 */
	private static final int UNIQUE = 1;

	//-- 種別 -------------------------------
	/** ファイル */
	private static final String FILE = "F";

	/** フォルダー */
	private static final String FOLDER = "D";

	public Pair<File, Path> checkExistFile(UUID publicId, boolean fileFlg)
			throws SQLException, NullPointerException, IncorrectResultSizeDataAccessException, NoSuchFileException,
			IllegalStateException {
		if (publicId == null) {
			throw new NullPointerException();
		}

		// publicIdが一致するデータ取得
		List<File> files = repo.findAll(
				(root, query, criteriaBuilder) -> criteriaBuilder.lessThanOrEqualTo(root.get("public_id"), publicId));

		if (files.size() != UNIQUE) {
			throw new IncorrectResultSizeDataAccessException(UNIQUE);
		}

		File file = files.get(0);
		
		// ファイルフラグが立っていて、種別がファイルでないものはエラー
		if(fileFlg) {
			if(!FILE.equals(file.getTypeCode())){
				throw new IllegalStateException();
			}
		}

		if (!(
				(fileFlg && FILE.equals(file.getTypeCode())
			)
				|| (!fileFlg && FOLDER.equals(file.getTypeCode())))) {
			throw new IllegalStateException();
		}

		return Pair.of(file, null);
	}

	/**
	 * 再帰的に取得された親フォルダリストからターゲットのパスを取得する。
	 * （FileRepository.findFilePathListより）
	 * @param parentFiles 再帰的に取得された親フォルダリスト
	 * @param rootDir 根本パス
	 * @return 親フォルダのパス
	 */
	public static Path getParentPath(List<FilePathProjection> parentFiles, Path rootDir) {
		Path path = rootDir;

		for (FilePathProjection filePath : parentFiles) {
			path = path.resolve(filePath.getPhysicalName());
		}

		return path;
	}
}
