package com.shiku.file.util.inflastructure.specifications;

import org.springframework.data.jpa.domain.Specification;

public class FileSpecifications {

	/**
	 * 親フォルダIDがNULLであるものを絞り込む。
	 * @return
	 */
	public static Specification<File> parentIdIsNull() {
		return (root, query, builder) -> {
			return builder.isNull(root.get("parentId"));
		};
	}

	/**
	 * 親フォルダIDが一致するものを絞り込む。
	 * @param parentId 親フォルダID
	 * @return
	 */
	public static Specification<File> parentIdEquals(Long parentId) {
		return (root, query, builder) -> {
			return builder.equal(root.get("parentId"), parentId);
		};
	}
}