package com.shiku.file.folder;

import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

import java.io.IOException;
import java.nio.file.NoSuchFileException;
import java.nio.file.Path;
import java.util.UUID;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.boot.webmvc.test.autoconfigure.WebMvcTest;
import org.springframework.data.util.Pair;
import org.springframework.http.MediaType;
import org.springframework.test.context.bean.override.mockito.MockitoBean;
import org.springframework.test.web.servlet.MockMvc;

import com.shiku.file.folder.application.request.FolderCreateRequest;
import com.shiku.file.folder.domain.FolderService;
import com.shiku.file.util.domain.service.FileUtilService;
import com.shiku.file.util.inflastructure.resource.File;

import tools.jackson.databind.ObjectMapper;

/**
 * FolderControllerのユニットテスト
 * MockMvcを使用して、実際のHTTPリクエストをシミュレートします。
 */
@WebMvcTest(FolderController.class) // Controller層のみをロードしてテストする設定
public class FolderControllerTest {

    @Autowired
    private MockMvc mockMvc; // HTTPリクエストを送るためのツール

    @MockitoBean
    private FolderService folderService; // Serviceをモック（身代わり）にする

    @MockitoBean
    private FileUtilService fileUtilService; // Serviceをモックにする

    @Autowired
    private ObjectMapper objectMapper; // JavaオブジェクトをJSONに変換するツール

    @Test
    @DisplayName("A-02: フォルダ作成 - 正常系（201 Created）")
    void createFolder_Success() throws Exception {
        // 1. 準備 (Given)
        UUID parentId = UUID.randomUUID();
        String folderName = "NewFolder";
        
        FolderCreateRequest request = new FolderCreateRequest();
        request.setParentId(parentId);
        request.setName(folderName);

        // モックの戻り値用データ作成
        File parentFile = File.builder().fileId(parentId.toString()).build();
        Path mockPath = Path.of("/dummy/path");
        File createdFolder = File.builder()
                .fileId(UUID.randomUUID().toString())
                .name(folderName)
                .physicalName("phys_" + folderName)
                .build();

        // サービスの動きを定義
        when(fileUtilService.checkExistFile(any(), anyBoolean()))
            .thenReturn(Pair.of(parentFile, mockPath));
        when(folderService.createFolder(any(), any(), any()))
            .thenReturn(createdFolder);

        // 2. 実行 & 3. 検証 (When & Then)
        mockMvc.perform(post("/api/folders")
                .contentType(MediaType.APPLICATION_JSON)
                .content(objectMapper.writeValueAsString(request))) // リクエスト体をJSON化
                .andExpect(status().isCreated()) // HTTP 201
                .andExpect(jsonPath("$.name").value(folderName)) // 戻り値のJSON検証
                .andExpect(jsonPath("$.fileId").exists());
    }

    @Test
    @DisplayName("A-02: フォルダ作成 - 異常系：親フォルダが存在しない（404 Not Found）")
    void createFolder_NotFound() throws Exception {
        // 準備
        FolderCreateRequest request = new FolderCreateRequest();
        request.setParentId(UUID.randomUUID());
        request.setName("ErrorFolder");

        // fileServiceで例外が発生するよう設定
        when(fileUtilService.checkExistFile(any(), anyBoolean()))
            .thenThrow(new NoSuchFileException("Parent not found"));

        // 実行 & 検証
        mockMvc.perform(post("/api/folders")
                .contentType(MediaType.APPLICATION_JSON)
                .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().isNotFound()); // switch文のNOT_EXISTに対応
    }

    @Test
    @DisplayName("A-02: フォルダ作成 - 異常系：書き込み失敗（409 Conflict）")
    void createFolder_CreateFail() throws Exception {
        // 準備
        FolderCreateRequest request = new FolderCreateRequest();
        request.setParentId(UUID.randomUUID());
        request.setName("FailFolder");

        when(fileUtilService.checkExistFile(any(), anyBoolean()))
            .thenReturn(Pair.of(File.builder().build(), Path.of("/")));
        
        // folderServiceでIOExceptionが発生するよう設定
        when(folderService.createFolder(any(), any(), any()))
            .thenThrow(new IOException("Disk Full"));

        // 実行 & 検証
        mockMvc.perform(post("/api/folders")
                .contentType(MediaType.APPLICATION_JSON)
                .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().isConflict()); // FOLDER_CREATE_FAILに対応
    }

    @Test
    @DisplayName("A-02: フォルダ作成 - 異常系：DBエラー（500 Internal Server Error）")
    void createFolder_SqlError() throws Exception {
        // 準備
        FolderCreateRequest request = new FolderCreateRequest();
        // サービスの動き：実行時にSQLException（RuntimeException系）を投げるように設定
        // ※SQLExceptionがチェック例外の場合はWrapperに包むか、RuntimeExceptionを継承している前提
        when(fileUtilService.checkExistFile(any(), anyBoolean()))
            .thenAnswer(invocation -> { throw new java.sql.SQLException("DB error"); });

        // 実行 & 検証
        mockMvc.perform(post("/api/folders")
                .contentType(MediaType.APPLICATION_JSON)
                .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().isInternalServerError());
    }
}
