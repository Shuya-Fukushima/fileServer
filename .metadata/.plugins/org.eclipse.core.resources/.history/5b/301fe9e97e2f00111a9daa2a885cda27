package com.shiku.file.items.domain;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.domain.Sort;
import org.springframework.data.jpa.domain.Specification;
import org.springframework.stereotype.Service;

import com.shiku.file.items.application.resource.ItemDto;
import com.shiku.file.util.db.file.File;
import com.shiku.file.util.db.file.FileRepository;
import com.shiku.file.util.inflastructure.specifications.FileSpecifications;

@Service
public class ItemsService {

	@Autowired
	private FileRepository fileRep;

	/**
	 * アイテム一覧取得
	 * @param parentId 親フォルダID
	 * @return
	 */
	public List<ItemDto> getItems(String parentId) {
		Specification<File> spec = null;

		// parentIdが空だった場合、一番上の階層のフォルダを取得する。
		if (parentId == null || parentId.isEmpty()) {
			spec = FileSpecifications.parentIdIsNull();
		}
		else {
			long num = 0;

			try {
				num = Long.parseLong(parentId);
			} catch (NumberFormatException e) {
				System.out.println("エラー: 数値として正しくない形式です。");
				return null;
			}

			spec = FileSpecifications.parentIdEquals(num);
		}

		List<File> files = null;

		try {
			files = fileRep.findAll(spec,
					Sort.by(Sort.Direction.ASC, "typeCode").and(Sort.by(Sort.Direction.ASC, "createdAt")));

		}
		catch (Exception e) {
			System.out.println("エラー: ファイル一覧の取得に失敗しました。");
			return null;
		}

		return files.stream().map(e -> toItemDto(e)).toList();
	}

	/**
	 * DTO変換メソッド
	 * @param file ファイルテーブルエンティティ
	 * @return ItemDto
	 */
	private ItemDto toItemDto(File file) {
		return ItemDto
				.builder()
				.fileId(file.getFileId())
				.publicId(file.getPublicId())
				.typeCode(file.getTypeCode())
				.name(file.getName())
				.physicalName(file.getPhysicalName())
				.createAt(file.getCreatedAt())
				.build();
	}
}
