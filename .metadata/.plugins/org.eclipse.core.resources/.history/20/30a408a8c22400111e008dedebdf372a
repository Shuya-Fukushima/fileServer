package com.shiku.file.folder.domain;

import java.nio.file.Path;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;

import com.shiku.file.folder.inflastructure.FilePathProjection;
import com.shiku.file.folder.inflastructure.FilePathRepository;

@Service
public class FolderService {

	@Autowired
	private FilePathRepository filePathRepo;

	@Value("${file.upload-dir:C:/uploads}")
	private Path rootDir;

	public void createFolder(Long parentId, String name) {
		Path parentPath = this.getParentPath(filePathRepo.findFilePathList(parentId));
		boolean result = parentPath.resolve("").toFile().mkdir();
	}

	/**
	 * 再帰的に取得された親フォルダリストからターゲットのパスを取得する。
	 * @param parentFiles 再帰的に取得された親フォルダリスト
	 * @return
	 */
	private Path getParentPath(List<FilePathProjection> parentFiles) {
		Path path = rootDir;

		for (FilePathProjection filePath : parentFiles) {
			rootDir.resolve(filePath.getPhysicalName());
		}

		return path;
	}
}
