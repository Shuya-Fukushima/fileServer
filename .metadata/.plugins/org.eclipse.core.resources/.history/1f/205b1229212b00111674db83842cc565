package com.shiku.file.transfer.domain;

import com.shiku.file.util.db.resource.File;

public enum FileTransferDomainResult {

	// 特に異常なく成功した場合
	SUCCESS(0),
	// 保存先となる親フォルダが存在しなかった場合
	PARENT_FOLDER_NOT_FOUND(1),
	// フォルダ作成に失敗した場合
	FOLDER_CREATE_FAIL(2),
	// DB関連で失敗した場合
	SQL_EXECUTE_FAIL(3),
	// 漢字半角英字変換で失敗した場合
	GEN_HALFWIDTH_FAIL(4);

	private int result;
	private File file;

	private FileTransferDomainResult(int result) {
		this.result = result;
	}

	public int getResult() {
		return this.result;
	}

	public void setFile(File file) {
		this.file = file;
	}

	public File getFile() {
		return this.file;
	}
}
